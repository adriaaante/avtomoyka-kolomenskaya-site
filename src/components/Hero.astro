---
import { site } from "../data/site";
import PhoneButton from "./ui/PhoneButton.astro";
import Icon from "./ui/Icon.astro";
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const publicDir = fileURLToPath(new URL("../../public/", import.meta.url));

function pickPhoto(name: string): string {
  const exts = ["jpg", "jpeg", "png", "webp", "avif", "svg"];
  for (const ext of exts) {
    if (existsSync(`${publicDir}photos/${name}.${ext}`)) {
      return `${base}/photos/${name}.${ext}`;
    }
  }
  return `${base}/photos/${name}.svg`;
}

const heroPhoto = pickPhoto("photo-1");

const title = "Машина, в которую хочется садиться";
const words = title.split(" ");
---

<section id="top" class="relative isolate min-h-[100svh] overflow-hidden pt-24 md:pt-28">
  <!-- Animated background -->
  <div data-hero-bg class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-ink-950"></div>
    <div class="absolute inset-0 bg-radial-spot"></div>
    <!-- floating droplets -->
    <div class="absolute left-[8%] top-[20%] h-2 w-2 rounded-full bg-brass-300 opacity-70 animate-float"></div>
    <div class="absolute right-[12%] top-[28%] h-3 w-3 rounded-full bg-brass-400 opacity-40 animate-float" style="animation-delay: 1s"></div>
    <div class="absolute left-[20%] bottom-[20%] h-2.5 w-2.5 rounded-full bg-brass-200 opacity-50 animate-float" style="animation-delay: 2s"></div>
    <div class="absolute right-[25%] bottom-[30%] h-1.5 w-1.5 rounded-full bg-white opacity-60 animate-float" style="animation-delay: 1.5s"></div>
    <!-- grid -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 56px 56px;"></div>
    <div class="absolute inset-0 bg-grid-fade"></div>
  </div>

  <div class="container-x relative grid min-h-[80svh] grid-cols-1 items-center gap-10 py-10 md:py-16 lg:grid-cols-12">
    <div class="lg:col-span-7">
      <span class="eyebrow">{site.address.metro} · {site.hoursShort}</span>

      <h1
        data-hero-title
        class="h-display mt-6 text-[clamp(2.5rem,7vw,5.5rem)] leading-[0.95] text-white text-balance"
      >
        {words.map((w, i) => (
          <span class="inline-block overflow-hidden pb-2">
            <span class={`inline-block ${i === words.length - 1 ? "shine-text" : ""}`}>
              {w}{i < words.length - 1 ? " " : ""}
            </span>
          </span>
        ))}
      </h1>

      <p data-hero-sub class="mt-7 max-w-xl text-lg text-white/75 md:text-xl text-balance">
        Ручная мойка, химчистка, полировка и детейлинг у м. Коломенская.
        Бережно к ЛКП, без записи, ежедневно с 9 до 22.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <span data-hero-cta><PhoneButton label={site.phone.display} /></span>
        <span data-hero-cta>
          <a href={site.whatsapp} target="_blank" rel="noopener" class="btn-ghost">
            <Icon name="message-circle" class="h-4 w-4" />
            WhatsApp
          </a>
        </span>
        <span data-hero-cta>
          <a href="#services" class="btn-ghost">
            <span>Услуги и цены</span>
            <Icon name="arrow-right" class="h-4 w-4" />
          </a>
        </span>
      </div>

      <div data-hero-cta class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-3 text-sm text-white/60">
        <div class="flex items-center gap-2">
          <Icon name="badge-check" class="h-4 w-4 text-brass-300" />
          <span>Только pH-нейтральная химия</span>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="badge-check" class="h-4 w-4 text-brass-300" />
          <span>Бесконтактная технология</span>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="badge-check" class="h-4 w-4 text-brass-300" />
          <span>Мастера со стажем от 4 лет</span>
        </div>
      </div>
    </div>

    <!-- Hero photo -->
    <div class="relative lg:col-span-5">
      <div class="relative mx-auto aspect-[4/5] w-full max-w-md overflow-hidden rounded-3xl border border-ink-700 shadow-card">
        <img
          src={heroPhoto}
          alt="Автомойка на Коломенской"
          loading="eager"
          decoding="async"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-950/80 via-ink-950/10 to-transparent"></div>
        <!-- 9–22 badge over photo -->
        <div class="absolute bottom-5 right-5 grid h-24 w-24 place-items-center rounded-full bg-brass-400 text-ink-950 shadow-glow">
          <div class="text-center">
            <div class="font-display text-2xl font-extrabold leading-none">9–22</div>
            <div class="mt-1 text-[8px] font-semibold uppercase tracking-[0.25em]">ежедневно</div>
          </div>
        </div>
        <span class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-full bg-ink-950/70 px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.25em] text-brass-200 backdrop-blur">
          <Icon name="map-pin" class="h-3 w-3" />
          Нагатинская, 1б
        </span>
      </div>
    </div>
  </div>

  <a href="#advantages" class="absolute inset-x-0 bottom-6 mx-auto grid w-fit place-items-center text-white/50 transition-colors hover:text-brass-300" aria-label="К содержимому">
    <span class="text-[10px] uppercase tracking-[0.3em]">Скролл</span>
    <Icon name="chevron-down" class="mt-2 h-5 w-5 animate-bounce" />
  </a>
</section>
