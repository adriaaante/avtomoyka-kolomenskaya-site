---
import { site } from "../data/site";
import SectionTitle from "./ui/SectionTitle.astro";
import Icon from "./ui/Icon.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
// Положите свои фото в public/photos/photo-1.* и photo-2.*
// Поддерживаются jpg / png / webp / svg
const photo1 = `${base}/photos/photo-1.svg`;
const photo2 = `${base}/photos/photo-2.svg`;
---

<section id="about" class="relative py-24 md:py-32">
  <div class="container-x">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-6">
        <SectionTitle
          eyebrow="О мойке"
          title="Маленькая мойка с большими амбициями"
          sub="Мы открылись на Нагатинской как «мойка для соседей» — и быстро стали тем местом, куда привозят машины с других районов Москвы."
        />
        <div class="mt-8 space-y-4 text-base leading-relaxed text-white/75">
          <p>
            Не пытаемся обмыть весь город. Зато про каждый кузов, который заехал в
            наш бокс, мы знаем — пройдёт ровно тот же путь: предмойка, пена,
            ручная промывка с двумя вёдрами, аккуратная сушка плюшевой
            микрофиброй и финиш на кварцевом воске.
          </p>
          <p>
            Не торопимся. Лучше потратим лишние 10 минут на проёмы и пороги, чем
            вернёмся через час с «недоделкой». У нас одна задача — чтобы вы сели в
            машину и подумали: «Чёрт, как же приятно».
          </p>
        </div>

        <div data-stagger class="mt-10 grid grid-cols-2 gap-4">
          {site.stats.map((s) => (
            <div
              data-stagger-item
              class="card relative overflow-hidden"
            >
              <div class="h-display flex items-baseline gap-1 text-3xl text-white md:text-4xl">
                <span data-counter={String(s.value)}>0</span>
                <span class="text-brass-300">{s.suffix}</span>
              </div>
              <div class="mt-2 text-[10px] uppercase tracking-[0.2em] text-white/50">
                {s.label}
              </div>
              <Icon name="sparkles" class="absolute -right-2 -top-2 h-14 w-14 text-brass-500/10" />
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-6">
        <div class="grid grid-cols-2 gap-4">
          <figure class="fade-in relative aspect-[3/4] overflow-hidden rounded-3xl border border-ink-700 shadow-card">
            <img
              src={photo1}
              alt="Автомойка Коломенская — фото 1"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1200ms] hover:scale-105"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-950/70 via-transparent to-transparent"></div>
          </figure>
          <figure class="fade-in relative mt-12 aspect-[3/4] overflow-hidden rounded-3xl border border-ink-700 shadow-card">
            <img
              src={photo2}
              alt="Автомойка Коломенская — фото 2"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-[1200ms] hover:scale-105"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-950/70 via-transparent to-transparent"></div>
          </figure>
        </div>

        <div class="mt-6 rounded-2xl border border-brass-500/30 bg-gradient-to-br from-brass-500/10 to-transparent p-6 fade-in">
          <div class="flex items-center gap-3">
            <Icon name="leaf" class="h-6 w-6 text-brass-300" />
            <h3 class="h-display text-lg text-white">Бережно к экологии</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-white/70">
            Биоразлагаемая химия, замкнутая система оборотного водоснабжения,
            LED-освещение. Меньше воды — больше пользы.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
