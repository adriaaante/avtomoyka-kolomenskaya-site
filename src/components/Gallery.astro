---
import { getCollection } from "astro:content";
import SectionTitle from "./ui/SectionTitle.astro";
import Icon from "./ui/Icon.astro";

const items = (await getCollection("gallery")).sort(
  (a, b) =>
    a.data.order - b.data.order ||
    b.data.date.getTime() - a.data.date.getTime(),
);

const categories: { key: string; label: string }[] = [
  { key: "all", label: "Все работы" },
  { key: "exterior", label: "Кузов" },
  { key: "interior", label: "Салон" },
  { key: "polish", label: "Полировка" },
  { key: "detailing", label: "Детейлинг" },
];

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const withBase = (p: string) => (p.startsWith("/") ? `${base}${p}` : p);
---

<section id="gallery" class="relative py-24 md:py-32">
  <div class="container-x">
    <SectionTitle
      eyebrow="Работы"
      title="Чистые машины из нашего бокса"
      sub="Фотографии без фильтров — после визита автомобиль выглядит именно так."
    />

    <div data-gallery class="mt-12">
      <div class="flex flex-wrap items-center gap-2">
        {categories.map((c, i) => (
          <button
            type="button"
            data-filter={c.key}
            class={`rounded-full border border-white/10 px-4 py-2 text-xs font-semibold tracking-wide text-white/70 transition-all hover:border-brass-400 hover:text-brass-200 ${i === 0 ? "is-active" : ""}`}
          >
            {c.label}
          </button>
        ))}
      </div>

      <div
        data-stagger
        class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4 lg:gap-6"
      >
        {items.map((it, i) => {
          const span = i % 5 === 0 ? "row-span-2 sm:row-span-2" : "";
          const aspect = i % 5 === 0 ? "aspect-[3/4]" : "aspect-[4/3]";
          return (
            <button
              data-stagger-item
              data-lightbox-trigger
              data-cat={it.data.category}
              data-src={withBase(it.data.image)}
              data-caption={it.data.title}
              type="button"
              class={`group relative overflow-hidden rounded-2xl border border-ink-700 bg-ink-900 ${aspect} ${span}`}
              aria-label={it.data.title}
            >
              <img
                src={withBase(it.data.image)}
                alt={it.data.title}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/20 to-transparent opacity-90"></div>
              <div class="absolute inset-x-0 bottom-0 p-4 text-left">
                <div class="text-[10px] uppercase tracking-[0.25em] text-brass-300">
                  {categories.find((c) => c.key === it.data.category)?.label}
                </div>
                <div class="mt-1 font-display text-sm font-semibold text-white line-clamp-2 md:text-base">
                  {it.data.title}
                </div>
              </div>
              <span class="absolute right-3 top-3 grid h-9 w-9 place-items-center rounded-full bg-ink-950/70 text-brass-200 opacity-0 transition-opacity group-hover:opacity-100">
                <Icon name="arrow-right" class="h-4 w-4 -rotate-45" />
              </span>
            </button>
          );
        })}
      </div>
    </div>
  </div>

  <dialog
    data-lightbox
    class="fixed inset-0 z-50 m-auto max-h-[90vh] max-w-5xl rounded-2xl border border-ink-700 bg-ink-950/95 p-2 text-white backdrop:bg-ink-950/80 backdrop:backdrop-blur"
  >
    <button
      type="button"
      data-lightbox-close
      class="absolute right-3 top-3 z-10 grid h-10 w-10 place-items-center rounded-full bg-ink-900/80 text-white hover:bg-brass-500 hover:text-ink-950"
      aria-label="Закрыть"
    >
      <Icon name="x" class="h-5 w-5" />
    </button>
    <img src="" alt="" class="block h-auto max-h-[80vh] w-full rounded-xl object-contain" />
    <div data-lightbox-caption class="px-5 py-3 text-center text-sm text-white/70"></div>
  </dialog>
</section>

<style is:global>
  [data-filter].is-active {
    background: theme("colors.brass.400");
    color: theme("colors.ink.950");
    border-color: theme("colors.brass.400");
  }
</style>
