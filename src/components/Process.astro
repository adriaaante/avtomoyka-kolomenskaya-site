---
import { site } from "../data/site";
import SectionTitle from "./ui/SectionTitle.astro";
---

<section id="process" data-process-track class="relative overflow-hidden py-24 md:py-32 lg:h-[100svh] lg:py-0">
  <div class="lg:flex lg:h-full lg:flex-col lg:justify-center">
    <div class="container-x">
      <SectionTitle
        eyebrow="Как мы моем"
        title="Пять шагов идеальной мойки"
        sub="Каждый автомобиль проходит один и тот же продуманный путь — отклонений нет."
      />
    </div>

    <div
      data-process-inner
      class="mt-12 flex flex-nowrap gap-5 px-5 md:gap-8 md:px-8 lg:mt-16 lg:px-[max(8vw,2rem)]"
    >
      {site.process.map((p) => (
        <article
          class="relative flex w-[280px] shrink-0 flex-col rounded-2xl border border-ink-700 bg-ink-900/70 p-7 backdrop-blur md:w-[340px] lg:w-[400px]"
        >
          <span class="h-display absolute right-5 top-4 text-7xl font-extrabold text-brass-500/15 lg:text-8xl">
            {p.step}
          </span>
          <span class="text-[10px] uppercase tracking-[0.3em] text-brass-300">Шаг {p.step}</span>
          <h3 class="h-display mt-4 text-2xl text-white lg:text-3xl">{p.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65 lg:text-base">{p.text}</p>
          <div class="mt-auto pt-6">
            <div class="h-px w-12 bg-brass-400/70"></div>
          </div>
        </article>
      ))}
      <div class="w-5 shrink-0 md:w-8"></div>
    </div>
  </div>
</section>
