---
import { site } from "../data/site";
import SectionTitle from "./ui/SectionTitle.astro";
import Icon from "./ui/Icon.astro";
---

<section id="advantages" class="relative py-24 md:py-32">
  <div class="container-x">
    <SectionTitle
      eyebrow="Почему мы"
      title="Премиум-подход к ежедневной мойке"
      sub="Шесть вещей, благодаря которым клиенты остаются с нами годами и приезжают через полгорода."
    />

    <div
      data-stagger
      class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3"
    >
      {site.advantages.map((adv) => (
        <article data-stagger-item class="card card-hover group">
          <div class="mb-5 inline-grid h-12 w-12 place-items-center rounded-xl bg-brass-500/10 text-brass-300 ring-1 ring-brass-500/20 transition-all group-hover:bg-brass-500/20 group-hover:text-brass-200">
            <Icon name={adv.icon} class="h-6 w-6" />
          </div>
          <h3 class="h-display text-xl text-white">{adv.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/65">{adv.text}</p>
          <div class="pointer-events-none absolute -right-16 -top-16 h-40 w-40 rounded-full bg-brass-500/10 blur-3xl opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
        </article>
      ))}
    </div>
  </div>
</section>
